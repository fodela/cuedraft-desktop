{
  "name": "cuedraft-desktop",
  "version": "0.1.0",
  "description": "System-wide text template picker",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/fodela/cuedraft-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/fodela/cuedraft-desktop/issues"
  },
  "homepage": "https://github.com/fodela/cuedraft-desktop#readme",
  "main": "out/main/index.js",
  "private": true,
  "scripts": {
    "predev": "electron-rebuild -f -w better-sqlite3 --only better-sqlite3",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "pretest": "npm rebuild better-sqlite3",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "postinstall": "electron-rebuild -f -w better-sqlite3 --only better-sqlite3",
    "dist": "npm run build && electron-builder --publish never",
    "dist:win": "npm run build && electron-builder --win --publish never",
    "dist:linux": "npm run build && electron-builder --linux --publish never",
    "dist:mac": "npm run build && electron-builder --mac --publish never"
  },
  "dependencies": {
    "@jitsi/robotjs": "^0.6.21",
    "better-sqlite3": "11",
    "react": "19",
    "react-dom": "19"
  },
  "devDependencies": {
    "electron": "32",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "4",
    "@vitest/coverage-v8": "^4.1.0",
    "electron-builder": "^26.8.1",
    "electron-rebuild": "^3.2.9",
    "electron-vite": "^5.0.0",
    "happy-dom": "^20.8.4",
    "tailwindcss": "4",
    "typescript": "^5.9.3",
    "vite": "6",
    "vitest": "^4.1.0"
  },
  "trustedDependencies": [
    "@jitsi/robotjs"
  ]
}
